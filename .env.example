# KranVergleich.de — local development overrides
# Copy this file to .env.local and fill in real values for development.
# Production values live in the Vercel project Environment Variables UI:
#   https://vercel.com/<team>/kranvergleich/settings/environment-variables
#
# This template is intentionally minimal. Only NEW vars introduced after
# 2026-05-12 (Commit 1 of the firm-notification rebuild) are listed below.
# The full operational spec — Supabase URL + service-role key, Resend API
# key, owner notification address, etc. — lives in the Vercel UI per the
# project's no-secrets-in-git rule.

# ============================================
# Firm-notification email (Zmiana 6 — founder signature, 2026-05-12)
# ============================================
# Name shown in the signature block of every firm-notification mail:
#   "Mit freundlichen Grüßen / <FOUNDER_NAME> / Gründer, KranVergleich.de"
# Default fallback in code: "Christoph Jonetzko" (matches Person schema on
# /ueber-uns + the LinkedIn profile, so the public identity stays consistent).
KRANVERGLEICH_FOUNDER_NAME=

# Public contact mailto target rendered under the signature. NOT the Resend
# FROM address (that one is noreply@send.kranvergleich.de, verified domain).
# This address has its own MX setup (forwards to the founder's private gmail
# per the project Resend / DNS config). Default fallback in code:
# "christoph@kranvergleich.de".
KRANVERGLEICH_FOUNDER_EMAIL=

# ============================================
# Signal-back loop (mig 026 + Commit 3, 2026-05-12)
# ============================================
# HMAC secret signing the accept/decline links embedded in firm-notification
# mails (/api/lead-response/[leadId]/[supplierId]?action=...&sig=...). Used
# by signLeadResponse() / verifyLeadResponseSig() in src/lib/lead-response-sig.ts.
# Generate locally with `openssl rand -hex 32` (64 hex chars = 256-bit secret;
# server slices a 22-char base64url window of the HMAC digest = 128-bit sig
# in the URL). Rotate by bumping the value here AND incrementing the
# sig_version DEFAULT in mig 026 so old rows stay verifiable.
LEAD_RESPONSE_SECRET=
